patch: patch-mario patch-zelda

patch-mario: $(BUILD_DIR)/gw_patch_mario.bin
	@echo "Applying patch via python script for mario..."
	python3 scripts/build/patch_firmware.py mario
	-$(RESTORE_KEYSTONE)

patch-zelda: $(BUILD_DIR)/gw_patch_zelda.bin
	@echo "Applying patch via python script for zelda..."
	python3 scripts/build/patch_firmware.py zelda
	-$(RESTORE_KEYSTONE)

ofw-crc:
	@echo "Generating baked OFW CRC signatures from patched artifacts..."
	python3 scripts/build/gen_ofw_crc.py

# Bake the Retro-Go internal-flash CRC (boot-time integrity gate). Run after build-rg-sd.
retrogo-crc:
	@echo "Generating baked Retro-Go CRC from retro-go-sd/build/gw_retro_go_intflash.bin..."
	python3 scripts/build/gen_retrogo_crc.py

.PHONY: patch patch-mario patch-zelda ofw-crc retrogo-crc
